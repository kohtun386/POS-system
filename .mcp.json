{
  "mcpServers": {
    "supabase-platform": {
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase",
        "--access-token",
        "${SUPABASE_ACCESS_TOKEN}",
        "--project-ref",
        "${SUPABASE_PROJECT_REF}"
      ]
    },
    "supabase-db": {
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-postgrest",
        "--apiUrl",
        "${SUPABASE_URL}",
        "--apiKey",
        "${SUPABASE_SERVICE_ROLE_KEY}",
        "--schema",
        "public"
      ]
    }
  }
}
