# ============================================
# Shared Variables (CLI, Proxy, MCP)
# ============================================

# Supabase CLI
SUPABASE_ACCESS_TOKEN=your-access-token-here
SUPABASE_PROJECT_REF=your-project-ref

# Edge Functions (used by supabase functions serve — do not commit real keys)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic Proxy
ANTHROPIC_BASE_URL=http://localhost:20128/v1
ANTHROPIC_AUTH_TOKEN=your-auth-token
ANTHROPIC_MODEL=your-model-name
ANTHROPIC_SMALL_FAST_MODEL=your-small-model

# Local Supabase (for MCP server)
LOCAL_SUPABASE_URL=http://localhost:54321
LOCAL_SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# ============================================
# Environment-Specific Frontend Variables
# ============================================
# These go in .env.development or .env.production

# For .env.development (local):
# VITE_SUPABASE_URL=http://localhost:54321
# VITE_SUPABASE_ANON_KEY=<get-from-supabase-status>

# For .env.production (cloud):
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=<get-from-dashboard>
